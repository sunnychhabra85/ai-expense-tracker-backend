# =============================================================
# Production Environment Variables for AWS EC2 Deployment
# Copy this file to .env.production and fill in your values
# =============================================================

# ── Node Environment ─────────────────────────────────────
NODE_ENV=production

# ── Database Configuration ───────────────────────────────
# PostgreSQL runs in Docker container
POSTGRES_DB=financedb
POSTGRES_USER=admin
POSTGRES_PASSWORD=YOUR_SECURE_POSTGRES_PASSWORD_HERE  # CHANGE THIS!

# ── JWT Secrets ──────────────────────────────────────────
# Generate with: openssl rand -base64 32
JWT_ACCESS_SECRET=YOUR_JWT_ACCESS_SECRET_MIN_32_CHARS  # CHANGE THIS!
JWT_REFRESH_SECRET=YOUR_JWT_REFRESH_SECRET_DIFFERENT  # CHANGE THIS!
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── Redis Configuration ──────────────────────────────────
# Generate with: openssl rand -base64 24
REDIS_PASSWORD=YOUR_SECURE_REDIS_PASSWORD  # CHANGE THIS!

# ── AWS Configuration ────────────────────────────────────
# AWS credentials for S3, SQS, Textract
AWS_REGION=us-east-1  # Free tier is best in us-east-1
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY

# S3 Bucket (create manually: aws s3 mb s3://your-bucket-name)
AWS_S3_BUCKET=your-finance-platform-bucket

# SQS Queue URL (create manually: aws sqs create-queue --queue-name document-processing)
AWS_SQS_PROCESSING_URL=https://sqs.us-east-1.amazonaws.com/YOUR_ACCOUNT_ID/document-processing

# ── OpenAI API Key ───────────────────────────────────────
# Required for AI features in processing and analytics
OPENAI_API_KEY=sk-YOUR_OPENAI_API_KEY_HERE  # Optional, but recommended

# ── Application Settings ─────────────────────────────────
BCRYPT_ROUNDS=10

# CORS - Replace with your domain or EC2 public IP
ALLOWED_ORIGINS=http://YOUR_EC2_PUBLIC_IP,https://YOUR_DOMAIN.com

# ── Service Ports (internal Docker network) ──────────────
# These are defaults and don't need to be changed
# PORT=3000  # API Gateway
# AUTH_SERVICE_PORT=3001
# UPLOAD_SERVICE_PORT=3002
# PROCESSING_SERVICE_PORT=3003
# ANALYTICS_SERVICE_PORT=3004
# NOTIFICATION_SERVICE_PORT=3005

# =============================================================
# IMPORTANT NOTES:
# =============================================================
# 1. NEVER commit this file with real values to Git
# 2. Generate strong random passwords for all secrets
# 3. Keep AWS credentials secure - use IAM roles if possible
# 4. Update ALLOWED_ORIGINS with your actual domain/IP
# 5. Make sure all _PASSWORD and _SECRET values are unique
# =============================================================

# Quick password generation commands:
# openssl rand -base64 32  # For JWT secrets
# openssl rand -base64 24  # For passwords
# uuidgen                  # For UUIDs
