{
  "compilerOptions": {
    "module": "commonjs",
    "declaration": true,
    "removeComments": true,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "target": "ES2021",
    "sourceMap": true,
    "outDir": "./dist",
    "baseUrl": "./",
    "incremental": true,
    "skipLibCheck": true,
    "strictNullChecks": true,
    "noImplicitAny": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "composite": false,
    "paths": {
      "@finance/shared-types": ["libs/shared-types/src/index.ts"],
      "@finance/shared-dtos": ["libs/shared-dtos/src/index.ts"],
      "@finance/database": ["libs/database/src/index.ts"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
