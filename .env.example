# =========================
# Core runtime
# =========================
NODE_ENV=development
ALLOWED_ORIGINS=http://localhost:3000

# =========================
# Database / Cache
# =========================
POSTGRES_DB=financedb
POSTGRES_USER=admin
POSTGRES_PASSWORD=localpassword123
POSTGRES_PORT=5432
DATABASE_URL=postgresql://admin:localpassword123@postgres:5432/financedb

REDIS_PASSWORD=localredispass
REDIS_PORT=6379
REDIS_URL=redis://:localredispass@redis:6379

# =========================
# AWS (LocalStack for local)
# =========================
AWS_REGION=ap-south-1
AWS_S3_BUCKET=finance-platform-uploads-dev
AWS_SQS_PROCESSING_URL=http://localstack:4566/000000000000/document-processing
AWS_ENDPOINT_URL=http://localstack:4566
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
LOCALSTACK_PORT=4566

# =========================
# Auth / Security
# =========================
JWT_ACCESS_SECRET=local-dev-access-secret-min-32-chars-ok
JWT_REFRESH_SECRET=local-dev-refresh-secret-different-value
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# =========================
# Optional AI APIs
# =========================
OPENAI_API_KEY=

# =========================
# Service ports
# =========================
AUTH_SERVICE_PORT=3001
UPLOAD_SERVICE_PORT=3002
PROCESSING_SERVICE_PORT=3003
ANALYTICS_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
